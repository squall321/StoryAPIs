# Copy to `.env` and fill in as needed. All values are OPTIONAL —
# the no-auth connectors (Gutendex, The Met, Wikidata, Open Library, PoetryDB)
# work with no keys at all.

# --- App ---
STORYAPIS_ENVIRONMENT=development
STORYAPIS_HTTP_TIMEOUT=20
# Comma-separated list of allowed CORS origins for the Vite dev server.
STORYAPIS_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Optional connector credentials (free signups) ---
STORYAPIS_EUROPEANA_API_KEY=
STORYAPIS_GEONAMES_USERNAME=
STORYAPIS_SMITHSONIAN_API_KEY=
STORYAPIS_CTEXT_API_KEY=
STORYAPIS_TROVE_API_KEY=
STORYAPIS_DATA_GO_KR_KEY=

# --- Story generation with Claude (optional, for /api/compose) ---
STORYAPIS_ANTHROPIC_API_KEY=
STORYAPIS_STORY_MODEL=claude-opus-4-8
